{
  "name": "careai-core-api",
  "version": "0.1.0",
  "private": true,
  "description": "Medical Document Recognition API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --target node20 --out-dir dist --clean --sourcemap",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "@sinclair/typebox": "^0.34.49",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "tesseract.js": "^7.0.0",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
