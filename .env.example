HOST=0.0.0.0
PORT=3000
FRONT_END_URL=http://localhost:5137

# TypeORM (required)
# DATABASE_URL=postgres://user:password@localhost:5432/careai
# NODE_ENV=local

# S3 (@aws-sdk/client-s3) — optional until you call S3 from code
# AWS_REGION=us-east-1
# S3_BUCKET=documents
# LocalStack (omit AWS_ENDPOINT_URL in real AWS)
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# Async document processing (SQS + worker)
# DOCUMENT_PROCESSING_QUEUE_URL=http://localhost:4566/000000000000/document-processing-queue
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OCR_TEXT_AUDIT_LIMIT=12000
# Max characters of OCR/plain text sent to Claude for structured extraction (default 72000).
# Lower = smaller payload and faster/cheaper; higher = more of long documents visible to the model.
# CLAUDE_EXTRACTION_INPUT_MAX_CHARS=72000
